# Copy to .env.local and fill in values. Do not commit .env.local.

# Mailchimp Transactional (Mandrill) — used by lib/email/sendEmail.ts for all outbound email
MANDRILL_API_KEY=md-UQkhizXrJDNIblyprzSmRQ
MAIL_FROM_EMAIL=noreply@mycashledger.com

# Amazon SES (optional legacy env vars; not read by sendEmail when using Mandrill — kept to avoid breaking other tooling)
# Preferred names (set in .env.local; do not commit secrets):
# AWS_SES_ACCESS_KEY=
# AWS_SES_SECRET_KEY=
# AWS_SES_REGION=ap-south-1
# AWS_SES_FROM_EMAIL=no-reply@your-verified-domain.com
# IAM: user needs ses:SendEmail + ses:SendRawEmail (often Resource identity/* for that region).
# SES sandbox: verify recipient addresses or request production access (sending domain must be verified).
# Legacy aliases (still supported):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
SES_FROM_EMAIL=noreply@mycashledger.com
# Optional: parallel campaign sends (default 5). Lower if you hit SES throttling in sandbox.
# SES_BULK_CONCURRENCY=5

# App URL (used in password reset and email links). No trailing space or slash.
APP_URL=https://mycashledger.com

# Optional: Cron jobs (e.g. subscription reminder)
CRON_SECRET=

# Next.js / App (optional)
NEXT_PUBLIC_APP_NAME=MyCashLedger
NEXT_PUBLIC_APP_URL=https://mycashledger.com

# Razorpay — set in .env.local (do not commit secrets)
# RAZORPAY_KEY_ID and NEXT_PUBLIC_RAZORPAY_KEY_ID must be the same Key ID.
# Test: rzp_test_*  |  Live (real settlements): rzp_live_* from Razorpay Dashboard → API Keys
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_WEBHOOK_SECRET=
