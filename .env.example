# Copy to .env.local and fill in values. Do not commit .env.local.

# Amazon SES (transactional email)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
SES_FROM_EMAIL=noreply@mycashledger.com

# App URL (used in password reset and email links)
APP_URL=http://localhost:3000

# Optional: Cron jobs (e.g. subscription reminder)
CRON_SECRET=

# Next.js / App (optional)
NEXT_PUBLIC_APP_NAME=Prantek
NEXT_PUBLIC_APP_URL=http://localhost:3000
